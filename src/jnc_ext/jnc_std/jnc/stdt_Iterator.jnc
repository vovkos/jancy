namespace stdt {

//! \addtogroup std-container
//! @{

//..............................................................................

struct IteratorBase<P> {
	typedef P EntryPtr;

	P readonly m_p;

	operator bool () thin const {
		return m_p != null;
	}

	P operator * () thin const {
		return m_p;
	}

	P operator -> () thin const {
		return m_p;
	}

	P operator ++ () thin {
		return m_p = m_p.m_next;
	}

	P operator -- () thin {
		return m_p = m_p.m_prev;
	}

	P postfix operator ++ () thin {
		P p0 = m_p;
		m_p = m_p.m_next;
		return p0;
	}

	P postfix operator -- () thin {
		P p0 = m_p;
		m_p = m_p.m_prev;
		return p0;
	}
}

// . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . .

// box lists, hashtables, trees, etc

struct ValueIteratorBase<V, P, E>: IteratorBase<E> {
	V operator * () thin const {
		return m_p.m_value;
	}

	P operator -> () thin const {
		return &m_p.m_value;
	}
}

struct ValueMutableIteratorBase<V, E>: ValueIteratorBase<V, V*, E> {
	V operator := (V value) thin const {
		return m_p.m_value = value;
	}
}

// . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . .

struct IteratorImpl<B, M>: B {
	construct() thin {}

	construct(EntryPtr p) thin {
		m_p = p;
	}

	construct(IteratorImpl<M, M> it) thin { // cast from mutable iterator
		m_p = it.m_p;
	}
}

// . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . .

typedef IteratorImpl<
	IteratorBase<T*>,
	IteratorBase<T*>
> Iterator<T>;

typedef IteratorImpl<
	IteratorBase<T const*>,
	IteratorBase<T*>
> ConstIterator<T>;

typedef jnc.AutoConst<
	Iterator<T>,
	ConstIterator<T>
> AutoConstIterator<T>;

typedef jnc.ReadOnly<
	Iterator<T>,
	ConstIterator<T>
> ReadOnlyIterator<T>;

//..............................................................................

//! @}

} // namespace stdt
